generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  createdAt    DateTime @default(now())
  planets      Planet[]
}

model Planet {
  id                String     @id @default(cuid())
  userId            String
  name              String
  type              String
  seed              String
  year              Int        @default(0)
  turnLengthYears   Int        @default(1)
  era               String     @default("Stone Age")
  threatLevel       String
  climate           String
  government        String
  culture           String
  mapData           Json
  resources         Json
  stats             Json
  discoveredTech    Json
  activeEvent       Json?
  alienRelations    Json
  history           Json
  winState          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  events            PlanetEvent[]
}

model PlanetEvent {
  id          String   @id @default(cuid())
  planetId    String
  year        Int
  category    String
  title       String
  description String
  choice      String
  outcome     String
  effects     Json
  createdAt   DateTime @default(now())
  planet      Planet   @relation(fields: [planetId], references: [id], onDelete: Cascade)
}
